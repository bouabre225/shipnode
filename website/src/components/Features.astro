---
const features = [
  ["Zero-downtime releases", "Timestamped directories and atomic symlink switching keep active traffic on the previous build until the new one is verified."],
  ["Health-gated deploys", "Configurable endpoint checks decide whether the release survives or rolls back automatically."],
  ["PM2 and Caddy templates", "Generated configs can be ejected, edited, and kept across future deploys."],
  ["Server hardening", "SSH, firewall, fail2ban, app users, and sudo policies can be managed from the same CLI surface."],
  ["Profiles and CI", "Deploy production, staging, or a custom config, then generate GitHub Actions workflows when you are ready."],
  ["Database and Redis setup", "Optional PostgreSQL, MySQL, SQLite, and Redis provisioning prepares services on the target server."],
];
---

<section class="shell-section features" id="features">
  <div class="shell-container">
    <div class="feature-head">
      <div>
        <p class="section-kicker">Library surface</p>
        <h2 class="section-title">A deploy tool made of readable shell modules.</h2>
      </div>
      <p class="section-copy">
        The CLI is split into focused modules for validation, prompts, package managers, templates,
        database setup, users, releases, and commands. That keeps the tool small enough to inspect.
      </p>
    </div>

    <div class="feature-grid">
      {features.map(([title, copy], index) => (
        <article class={`feature feature-${index + 1}`}>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{title}</h3>
          <p>{copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-head {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(300px, 0.65fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: end;
    margin-bottom: clamp(2rem, 5vw, 4.5rem);
  }

  .section-title {
    margin-top: 1rem;
    max-width: 760px;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr 1fr;
    gap: 1px;
    background: var(--border-primary);
    border: 1px solid var(--border-primary);
  }

  .feature {
    min-height: 240px;
    padding: clamp(1.25rem, 2.8vw, 2rem);
    background: var(--bg-primary);
    transition: background var(--transition-base), transform var(--transition-fast);
  }

  .feature:hover {
    background: var(--bg-secondary);
  }

  .feature:active {
    transform: scale(0.995);
  }

  .feature-1 {
    grid-row: span 2;
  }

  .feature-4 {
    grid-column: span 2;
  }

  .feature span {
    display: inline-block;
    color: var(--accent-hover);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    margin-bottom: 3rem;
  }

  .feature h3 {
    font-size: clamp(1.15rem, 2vw, 1.65rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .feature p {
    margin-top: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.94rem;
    line-height: 1.65;
    text-wrap: pretty;
  }

  @media (max-width: 980px) {
    .feature-head,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .feature-1,
    .feature-4 {
      grid-row: auto;
      grid-column: auto;
    }

    .feature {
      min-height: 0;
    }

    .feature span {
      margin-bottom: 1.5rem;
    }
  }
</style>
