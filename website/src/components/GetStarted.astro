---
---

<section class="shell-section get-started" id="get-started">
  <div class="shell-container cta">
    <div>
      <p class="section-kicker">Start shipping</p>
      <h2 class="section-title">Install once. Deploy from the project folder.</h2>
    </div>
    <div class="cta-panel">
      <code>curl -fsSL https://shipnode.dev/install -o shipnode-installer.sh && bash shipnode-installer.sh</code>
      <div class="cta-links">
        <a href="https://github.com/devalade/shipnode" target="_blank" rel="noopener" class="primary">View source</a>
        <a href="https://github.com/devalade/shipnode#getting-started" target="_blank" rel="noopener">Read docs</a>
      </div>
    </div>
  </div>
</section>

<style>
  .get-started {
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }

  .cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(340px, 0.78fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: end;
  }

  .section-title {
    margin-top: 1rem;
    max-width: 850px;
  }

  .cta-panel {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--bg-code);
    box-shadow: inset 0 1px 0 rgba(237, 237, 223, 0.08);
    padding: clamp(1.2rem, 3vw, 2rem);
    min-width: 0;
  }

  .cta-panel code {
    display: block;
    color: var(--text-primary);
    font-size: clamp(0.74rem, 1.4vw, 0.9rem);
    line-height: 1.7;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: thin;
  }

  .cta-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .cta-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    padding: 0.7rem 1rem;
    font-weight: 600;
    font-size: 0.9rem;
    transition: transform var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
  }

  .cta-links .primary {
    background: var(--bg-rail);
    color: var(--text-invert);
    border-color: transparent;
  }

  .cta-links a:hover {
    border-color: var(--accent-primary);
    background: var(--accent-muted);
  }

  .cta-links .primary:hover {
    background: var(--accent-hover);
  }

  .cta-links a:active {
    transform: scale(0.98) translateY(1px);
  }

  @media (max-width: 900px) {
    .cta {
      grid-template-columns: 1fr;
    }
  }
</style>
