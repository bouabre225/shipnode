<section class="get-started" id="get-started">
  <div class="container">
    <div class="cta-card">
      <div class="cta-glow"></div>
      <h2>Ready to ship?</h2>
      <p>Install ShipNode and deploy your first app in under 5 minutes.</p>
      <div class="cta-code">
        <code>curl -fsSL https://shipnode.dev/install | bash</code>
      </div>
      <div class="cta-links">
        <a href="https://github.com/devalade/shipnode" target="_blank" rel="noopener" class="cta-btn" id="cta-github">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View on GitHub
        </a>
        <a href="https://github.com/devalade/shipnode#getting-started" target="_blank" rel="noopener" class="cta-link">
          Read the docs →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .get-started {
    padding: var(--space-4xl) var(--space-xl);
    border-top: 1px solid var(--border-primary);
  }
  .container { max-width: 700px; margin: 0 auto; }
  .cta-card {
    position: relative;
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }
  .cta-glow {
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-card h2 {
    position: relative;
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }
  .cta-card p {
    position: relative;
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: var(--space-xl);
  }
  .cta-code {
    position: relative;
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--accent-hover);
    background: var(--bg-code);
    border: 1px solid var(--border-primary);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-xl);
  }
  .cta-links {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.75rem 1.5rem;
    background: var(--text-primary);
    color: var(--bg-primary);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.875rem;
    transition: opacity var(--transition-fast);
  }
  .cta-btn:hover { opacity: 0.9; }
  .cta-link {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 500;
    transition: color var(--transition-fast);
  }
  .cta-link:hover { color: var(--text-primary); }
</style>
