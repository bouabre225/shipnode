---
---

<section class="hero" id="hero">
  <div class="hero-glow"></div>
  <div class="hero-content">
    <div class="badge">
      <span class="badge-dot"></span>
      <span>v1.3 — Now with config ejection & metrics</span>
    </div>
    <h1>Deploy Node.js apps<br /><span class="gradient-text">with a single command</span></h1>
    <p class="subtitle">
      Ship to your own server over SSH. No Kubernetes, no Docker, no vendor lock-in.
      Zero-downtime deployments, automatic HTTPS, and instant rollbacks.
    </p>
    <div class="hero-actions">
      <div class="install-cmd" id="install-cmd">
        <code>curl -fsSL https://shipnode.dev/install | bash</code>
        <button class="copy-btn" id="copy-btn" aria-label="Copy install command">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        </button>
      </div>
      <a href="#how-it-works" class="btn-secondary" id="learn-more-btn">See how it works →</a>
    </div>
    <div class="terminal" id="terminal-demo">
      <div class="terminal-bar">
        <div class="terminal-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="terminal-title">terminal</span>
        <div style="width:52px"></div>
      </div>
      <div class="terminal-body">
        <pre><code><span class="t-muted">$</span> <span class="t-green">shipnode</span> init <span class="t-muted">&& shipnode deploy</span>

<span class="t-blue">→</span> Detected framework: <span class="t-white">Express</span>
<span class="t-blue">→</span> App type: <span class="t-white">backend</span>
<span class="t-blue">→</span> Creating shipnode.conf...

<span class="t-muted">$</span> <span class="t-green">shipnode</span> deploy

<span class="t-blue">▶</span> Syncing files via rsync...
<span class="t-blue">▶</span> Installing dependencies...
<span class="t-blue">▶</span> Building application...
<span class="t-blue">▶</span> Switching to release <span class="t-white">20260408143022</span>
<span class="t-blue">▶</span> Reloading PM2 (zero-downtime)...
<span class="t-blue">▶</span> Health check: <span class="t-green">200 OK</span> <span class="t-muted">(23ms)</span>

<span class="t-green">✔</span> Deployed successfully in <span class="t-white">45s</span>
  <span class="t-muted">https://api.myapp.com</span></code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 10rem var(--space-xl) var(--space-4xl);
    text-align: center;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.375rem 1rem;
    background: var(--bg-badge);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: var(--radius-full);
    font-size: 0.8125rem;
    color: var(--accent-hover);
    margin-bottom: var(--space-xl);
    font-weight: 500;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--accent-primary);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
  }

  .gradient-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 580px;
    margin: 0 auto var(--space-2xl);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  .install-cmd {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--bg-elevated);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: border-color var(--transition-fast);
  }
  .install-cmd:hover { border-color: var(--border-accent); }
  .install-cmd code { color: var(--accent-hover); }

  .copy-btn {
    background: none;
    border: none;
    color: var(--text-tertiary);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color var(--transition-fast);
    display: flex;
    align-items: center;
  }
  .copy-btn:hover { color: var(--text-primary); }

  .btn-secondary {
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
    font-weight: 500;
  }
  .btn-secondary:hover { color: var(--text-primary); }

  /* Terminal */
  .terminal {
    max-width: 620px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-primary);
    background: var(--bg-code);
    overflow: hidden;
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    text-align: left;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-primary);
  }
  .terminal-dots { display: flex; gap: 6px; }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }
  .terminal-title { font-size: 0.75rem; color: var(--text-tertiary); }
  .terminal-body { padding: 1.25rem; }
  .terminal-body pre {
    font-size: 0.8125rem;
    line-height: 1.7;
    overflow-x: auto;
  }
  .t-green { color: var(--green); }
  .t-blue { color: var(--accent-hover); }
  .t-muted { color: var(--text-tertiary); }
  .t-white { color: var(--text-primary); }

  @media (max-width: 640px) {
    .hero { padding-top: 7rem; }
    .install-cmd { font-size: 0.75rem; }
  }
</style>

<script>
  document.getElementById("copy-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText("curl -fsSL https://shipnode.dev/install | bash");
    const btn = document.getElementById("copy-btn");
    if (btn) {
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      setTimeout(() => {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
      }, 2000);
    }
  });
</script>
