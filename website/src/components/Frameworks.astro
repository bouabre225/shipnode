---
const columns = [
  ["Backends", ["Express", "NestJS", "Fastify", "Koa", "Hono", "AdonisJS"]],
  ["Full-stack", ["Next.js", "Nuxt", "Remix", "Astro"]],
  ["Frontends", ["React", "Vue", "Svelte", "Angular", "SolidJS"]],
  ["Package managers", ["npm", "yarn", "pnpm", "bun"]],
];
---

<section class="shell-section frameworks" id="frameworks">
  <div class="shell-container">
    <div class="framework-head">
      <p class="section-kicker">Detection matrix</p>
      <h2 class="section-title">Bring the stack you already picked.</h2>
      <p class="section-copy">
        ShipNode reads the local project, picks the right install/build/start commands,
        and lets config override the rare case where auto-detection is not enough.
      </p>
    </div>

    <div class="matrix" aria-label="Supported frameworks and package managers">
      {columns.map(([label, items]) => (
        <section class="matrix-column">
          <h3>{label}</h3>
          <div class="chips">
            {items.map((item) => <span>{item}</span>)}
          </div>
        </section>
      ))}
    </div>
  </div>
</section>

<style>
  .framework-head {
    display: grid;
    gap: 1.25rem;
    justify-items: start;
    margin-bottom: clamp(2rem, 5vw, 4rem);
    max-width: 820px;
  }

  .section-title {
    margin-top: 1rem;
    max-width: 720px;
  }

  .section-copy {
    max-width: 640px;
  }

  .matrix {
    display: grid;
    grid-template-columns: 1.1fr 0.8fr 1.05fr 0.7fr;
    gap: 1px;
    background: var(--border-primary);
    border: 1px solid var(--border-primary);
  }

  .matrix-column {
    background: var(--bg-primary);
    padding: clamp(1.2rem, 2.5vw, 1.75rem);
  }

  h3 {
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.35rem;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .chips span {
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    color: var(--text-primary);
    background: var(--bg-soft);
    padding: 0.45rem 0.72rem;
    font-size: 0.86rem;
    line-height: 1;
    transition: border-color var(--transition-fast), transform var(--transition-fast), background var(--transition-fast);
  }

  .chips span:hover {
    border-color: var(--accent-primary);
    background: var(--accent-muted);
    transform: translateY(-1px);
  }

  .chips span:active {
    transform: scale(0.98);
  }

  @media (max-width: 980px) {
    .matrix {
      grid-template-columns: 1fr;
    }
  }
</style>
